# Database
DATABASE_URL=mongodb://localhost:27017/medicare

# JWT
JWT_SECRET=your-super-secret-jwt-key-here

# Server
PORT=4000
NODE_ENV=development

# CORS - Comma separated list of allowed origins
# For production, include your frontend domains (Vercel, etc.)
CORS_ORIGINS=http://localhost:3000,exp://127.0.0.1:19000,http://localhost:4000,http://localhost:3001,https://media-care-admin.vercel.app

# Agora Video SDK
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMS Service (sender.ge or Twilio)
# Option 1: sender.ge (recommended for Georgia)
# Get API key from https://sender.ge
SENDER_GE_API_KEY=40d8454e1a43a4ce7d36e098f09e5d89
# Sender number (smsno) - Get from sender.ge dashboard
# If not set, defaults to '204898780'
SENDER_GE_SMSNO=204898780

# Option 2: Twilio SMS (for phone verification)
# Get credentials from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890  # Your Twilio phone number (E.164 format, e.g., +995555123456)
